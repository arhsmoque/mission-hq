{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mission-hq",
  "compatibility_date": "2026-05-13",
  "main": "./src/worker.ts",
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
